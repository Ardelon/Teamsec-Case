              ],
              "body": "{\n  \"tenant_id\": \"BANK001\",\n  \"loan_type\": \"RETAIL\",\n  \"extraction_date\": \"2026-07-12T14:50:12Z\",\n  \"credits\": [\n    {\n      \"loan_account_number\": \"LN_RETAIL_90841\",\n      \"customer_id\": \"CUST_89301\",\n      \"customer_type\": \"K\",\n      \"loan_status_code\": \"A\",\n      \"days_past_due\": 12,\n      \"final_maturity_date\": \"2031-12-15\",\n      \"original_loan_amount\": 250000.0,\n      \"outstanding_principal_balance\": 210450.15,\n      \"nominal_interest_rate\": 0.185,\n      \"retail_specific_attributes\": {\n        \"insurance_included\": \"Y\",\n        \"customer_province_code\": \"34\"\n      },\n      \"commercial_specific_attributes\": {},\n      \"payment_schedule\": [\n        {\n          \"installment_number\": 13,\n          \"scheduled_payment_date\": \"2026-08-15\",\n          \"installment_amount\": 5840.5,\n          \"installment_status\": \"P\"\n        }\n      ]\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Profiling Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/profiling?loan_type={{loan_type}}",
              "host": ["{{base_url}}"],
              "path": ["api", "profiling"],
              "query": [
                {
                  "key": "loan_type",
                  "value": "{{loan_type}}",
                  "description": "Required: RETAIL | COMMERCIAL"
                }
              ]
            },
            "description": "Single-pass statistical profiling for dashboard charts.\n\nIncludes both backend fields (numerical_fields, categorical_fields) and frontend chart payload (summary, charts.categorical_distributions)."
          },
          "response": [
