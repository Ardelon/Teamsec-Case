                }
              ],
              "body": "{\n  \"tenant_id\": \"BANK001\",\n  \"loan_type\": \"RETAIL\",\n  \"generated_at\": \"2026-07-12T15:00:00Z\",\n  \"total_records_processed\": 50000,\n  \"total_records\": 50000,\n  \"numerical_fields\": {\n    \"original_loan_amount\": {\n      \"min\": 5000.0,\n      \"max\": 1200000.0,\n      \"avg\": 345000.75,\n      \"stddev\": 89045.12,\n      \"null_ratio\": 0.0\n    }\n  },\n  \"categorical_fields\": {\n    \"loan_status_code\": {\n      \"unique_values_count\": 3,\n      \"most_frequent_value\": \"A\",\n      \"null_ratio\": 0.0\n    }\n  },\n  \"summary\": {\n    \"total_records\": 50000,\n    \"null_fields_distribution\": [\n      { \"field\": \"loan_closing_date\", \"ratio\": 0.854 }\n    ]\n  },\n  \"charts\": {\n    \"categorical_distributions\": {\n      \"loan_status_code\": [\n        { \"value\": \"A\", \"count\": 42000 },\n        { \"value\": \"K\", \"count\": 8000 }\n      ]\n    }\n  }\n}"
            }
          ]
        }
      ]
    }
  ]
}
