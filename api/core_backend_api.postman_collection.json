{
  "info": {
    "_postman_id": "b2c3d4e5-f6a7-8901-bcde-f23456789012",
    "name": "Core Backend REST API",
    "description": "Postman collection for the TeamSec core_backend_api Django service (App 3).\n\nBase URL defaults to http://localhost:8000 (docker-compose core_backend_api).\n\nDemo credentials (seed_operators):\n- username: operator_admin\n- password: secure_cleartext_password\n- tenant_id: BANK001\n\nValid tenant_id values: BANK001, BANK002, BANK003\nValid loan_type values: RETAIL, COMMERCIAL\n\nBrowser UI uses HttpOnly Django session cookies (not localStorage).\nRun \"Login\" first — session cookie is set; the test script also stores {{jwt_token}} for Bearer auth if preferred.\nRun \"Trigger Sync\" — the test script stores {{job_id}} for status polling.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "username",
      "value": "operator_admin"
    },
    {
      "key": "password",
      "value": "secure_cleartext_password"
    },
    {
      "key": "tenant_id",
      "value": "BANK001"
    },
    {
      "key": "loan_type",
      "value": "RETAIL"
    },
    {
      "key": "jwt_token",
      "value": ""
    },
    {
      "key": "job_id",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/health/",
              "host": ["{{base_url}}"],
              "path": ["api", "health", ""]
            },
            "description": "Public health probe. No authentication required."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"status\": \"ok\",\n  \"service\": \"core_backend_api\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', body.token);",
                  "    pm.collectionVariables.set('tenant_id', body.tenant_id);",
                  "    pm.test('Token received', () => pm.expect(body.token).to.be.a('string'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"tenant_id\": \"{{tenant_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Validates operator credentials, creates an HttpOnly session cookie, and returns scoped claims.\n\nAlso returns an optional Bearer token for API tooling. The UI never stores the token in localStorage — it relies on the session cookie.\nTenant for subsequent UI requests comes from the session."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"expires_at\": \"2026-07-12T16:00:00Z\",\n  \"tenant_id\": \"BANK001\"\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"error\": \"Invalid credentials\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Sync",
      "item": [
        {
          "name": "Trigger Sync",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 202) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('job_id', body.job_id);",
                  "    pm.test('Job queued', () => pm.expect(body.status).to.eql('QUEUED'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"loan_type\": \"{{loan_type}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/sync",
              "host": ["{{base_url}}"],
              "path": ["api", "sync"]
            },
            "description": "Acquires a Redis distributed lock (lock:{tenant_id}:{loan_type}, TTL 600s) and queues a Celery ETL job.\n\nRequires Authorization: Bearer {{jwt_token}}.\nTenant is taken from JWT claims — do not pass tenant_id in the body."
          },
          "response": [
            {
              "name": "202 Accepted",
              "status": "Accepted",
              "code": 202,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"job_id\": \"job_d3b07384-d113-4a64-bc0f-90af9b28b584\",\n  \"tenant_id\": \"BANK001\",\n  \"loan_type\": \"RETAIL\",\n  \"status\": \"QUEUED\",\n  \"created_at\": \"2026-07-12T14:57:00Z\"\n}"
            },
            {
              "name": "409 Conflict",
              "status": "Conflict",
              "code": 409,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"error\": \"A pipeline processing cycle is actively running for this specific tenant and credit selection selection.\",\n  \"active_job_id\": \"job_e9112b42-7482-411a-8b1e-01fc8b284e11\"\n}"
            }
          ]
        },
        {
          "name": "Sync Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/sync/status/{{job_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "sync", "status", "{{job_id}}"]
            },
            "description": "Polls background job progress. Use {{job_id}} from Trigger Sync response.\n\nFrontend polls every 3s until status is COMPLETED or FAILED."
          },
          "response": [
            {
              "name": "200 OK - Processing",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"job_id\": \"job_d3b07384-d113-4a64-bc0f-90af9b28b584\",\n  \"tenant_id\": \"BANK001\",\n  \"loan_type\": \"RETAIL\",\n  \"status\": \"PROCESSING\",\n  \"progress_percentage\": 48,\n  \"processed_rows\": 96400,\n  \"records_processed\": 96400,\n  \"started_at\": \"2026-07-12T14:57:02Z\",\n  \"completed_at\": null,\n  \"errors\": [],\n  \"validation_summary\": {}\n}"
            },
            {
              "name": "200 OK - Completed",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"job_id\": \"job_d3b07384-d113-4a64-bc0f-90af9b28b584\",\n  \"tenant_id\": \"BANK001\",\n  \"loan_type\": \"RETAIL\",\n  \"status\": \"COMPLETED\",\n  \"progress_percentage\": 100,\n  \"processed_rows\": 150000,\n  \"records_processed\": 150000,\n  \"started_at\": \"2026-07-12T14:57:02Z\",\n  \"completed_at\": \"2026-07-12T14:58:30Z\",\n  \"errors\": [],\n  \"validation_summary\": {\n    \"is_valid\": true,\n    \"error_count\": 0,\n    \"critical_failures\": []\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Warehouse",
      "item": [
        {
          "name": "Data Snapshot",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/data?loan_type={{loan_type}}",
              "host": ["{{base_url}}"],
              "path": ["api", "data"],
              "query": [
                {
                  "key": "loan_type",
                  "value": "{{loan_type}}",
                  "description": "Required: RETAIL | COMMERCIAL"
                },
                {
                  "key": "tenant_id",
                  "value": "{{tenant_id}}",
                  "description": "Optional — must match JWT claim or returns 403",
